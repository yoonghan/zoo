{
	"name": "zoonegara",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "jest --watch",
		"test:single": "jest",
		"test:coverage": "jest --coverage --no-cache",
		"e2e": "playwright test",
		"e2e:ui": "playwright test --ui",
		"e2e:smoke": "playwright test --config ./e2e/smoke/playwright.config.ts",
		"snapshot": "node ./scripts/generate-backstop-config.mjs && backstop test",
		"snapshot:approve": "backstop approve",
		"dependency:check": "knip"
	},
	"dependencies": {
		"@fortawesome/fontawesome-svg-core": "^7.2.0",
		"@fortawesome/free-regular-svg-icons": "^7.2.0",
		"@fortawesome/free-solid-svg-icons": "^7.2.0",
		"@fortawesome/react-fontawesome": "^3.3.1",
		"accept-language": "^3.0.20",
		"happy-dom": "^20.9.0",
		"i18next": "^26.3.1",
		"i18next-resources-to-backend": "^1.2.1",
		"lodash": "^4.18.1",
		"next": "^16.2.6",
		"react": "^19.2.7",
		"react-confirm": "^0.5.0",
		"react-dom": "^19.2.7",
		"react-ga4": "^3.0.1",
		"react-i18next": "^17.0.8",
		"react-slick": "^0.31.0",
		"slick-carousel": "^1.8.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@happy-dom/jest-environment": "^20.10.3",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/postcss": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/jest": "^30.0.0",
		"@types/lodash": "^4.17.24",
		"@types/node": "^26.1.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@types/react-slick": "^0.23.13",
		"autoprefixer": "^10.5.0",
		"backstopjs": "^6.3.23",
		"jest": "^30.2.0",
		"jest-environment-jsdom": "^30.4.1",
		"knip": "^6.14.1",
		"postcss": "^8.5.16",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.3"
	}
}
