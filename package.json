{
	"name": "zoonegara",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "jest --watch",
		"test:single": "jest",
		"test:coverage": "jest --coverage --no-cache",
		"e2e": "playwright test",
		"e2e:ui": "playwright test --ui",
		"e2e:smoke": "playwright test --config ./e2e/smoke/playwright.config.ts",
		"snapshot": "node ./scripts/generate-backstop-config.mjs && backstop test",
		"snapshot:approve": "backstop approve",
		"dependency:check": "knip"
	},
	"dependencies": {
		"@fortawesome/fontawesome-svg-core": "^7.2.0",
		"@fortawesome/free-regular-svg-icons": "^7.2.0",
		"@fortawesome/free-solid-svg-icons": "^7.2.0",
		"@fortawesome/react-fontawesome": "^3.3.1",
		"accept-language": "^3.0.20",
		"happy-dom": "^20.9.0",
		"i18next": "^25.10.4",
		"i18next-resources-to-backend": "^1.2.1",
		"lodash": "^4.18.1",
		"next": "^16.2.4",
		"react": "^19.2.0",
		"react-confirm": "^0.5.0",
		"react-dom": "^19.2.5",
		"react-ga4": "^3.0.1",
		"react-i18next": "^16.5.4",
		"react-slick": "^0.31.0",
		"slick-carousel": "^1.8.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@happy-dom/jest-environment": "^20.6.1",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/postcss": "^4.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/jest": "^30.0.0",
		"@types/lodash": "^4.17.24",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.2",
		"@types/react-dom": "^19.2.3",
		"@types/react-slick": "^0.23.13",
		"autoprefixer": "^10.4.24",
		"backstopjs": "^6.3.23",
		"jest": "^30.2.0",
		"jest-environment-jsdom": "^30.2.0",
		"knip": "^5.85.0",
		"postcss": "^8",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3"
	}
